# Postgres credentials used by docker-compose. Leave these as-is unless
# you're pointing at an external database.
POSTGRES_USER=asura
POSTGRES_PASSWORD=asura
POSTGRES_DB=asura

# Backend database. Override with a real Postgres URL in production.
# When ASURA_USE_SQL is unset, Asura uses an in-memory store seeded from
# demo_store on each restart (handy for the demo flow + fast tests).
# Set ASURA_USE_SQL=1 to enable persistence; the default DB is SQLite at
# ./asura.db.  Switch to Postgres by setting DATABASE_URL below.
ASURA_USE_SQL=
DATABASE_URL=postgresql+psycopg://asura:asura@db:5432/asura

# Redis (used by the optional RQ worker for async scans).
REDIS_URL=redis://redis:6379/0

# Scanner runtime knobs. See docs/SCANNER_RUNNERS.md for the full set.
ASURA_MODE=passive
ASURA_EVIDENCE_DIR=/data/evidence
# ASURA_DEMO_MODE=1            # freeze every scan on seeded output
# ASURA_PREFER_DOCKER=1        # always run scanners in their Docker image
# ASURA_ENABLE_REAL_SCANNERS=1 # legacy alias of "off"-by-default demo mode

# Frontend → backend wire.
NEXT_PUBLIC_API_URL=http://localhost:8000
